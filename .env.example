# Vibe Lab Environment Configuration
# Full reference: docs/configuration.md
#
# CLI commands: vibelab | vibelab start | vibelab status | vibelab help | vibelab version

# =============================================================================
# SERVER
# =============================================================================
PORT=3001
VITE_PORT=5173
# Host/IP to bind servers to (default: 0.0.0.0 for all interfaces)
# Use 127.0.0.1 to restrict to localhost only
HOST=0.0.0.0
# CLAUDE_CLI_PATH=claude
# CURSOR_CLI_PATH=agent

# =============================================================================
# CONTEXT WINDOW
# =============================================================================
CONTEXT_WINDOW=160000
VITE_CONTEXT_WINDOW=160000


# =============================================================================
# DATABASE
# =============================================================================
# DATABASE_PATH=/path/to/custom/auth.db

# =============================================================================
# AUTHENTICATION  [SECURITY-SENSITIVE]
# =============================================================================
# IMPORTANT: Change JWT_SECRET before exposing VibeLab outside localhost!
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=change-me-to-a-random-string
# API_KEY=

# =============================================================================
# PLATFORM MODE  (advanced — most users leave these commented out)
# =============================================================================
# VITE_IS_PLATFORM=false
# WORKSPACES_ROOT=/home/user/projects

# =============================================================================
# INTEGRATIONS  (optional)
# =============================================================================
# OPENAI_API_KEY=sk-...

# =============================================================================
# LATEXLAB PHASE-1 INTEGRATION
# =============================================================================

# Enable or disable LatexLab proxy integration in VibeLab
LATEXLAB_ENABLED=false

# Path prefixes exposed by VibeLab
LATEXLAB_API_PREFIX=/latexlab-api

# Upstream LatexLab services (independent process)
LATEXLAB_API_TARGET=http://localhost:8787

# Proxy timeout in milliseconds
LATEXLAB_PROXY_TIMEOUT_MS=120000
LATEXLAB_PORT=8787
LATEXLAB_DATA_DIR=./apps/latexlab/data

LATEXLAB_LLM_API_KEY=
LATEXLAB_LLM_MODEL=claude
LATEXLAB_COLLAB_TOKEN_SECRET=latexlab-collab-dev
LATEXLAB_COLLAB_REQUIRE_TOKEN=true
LATEXLAB_COLLAB_TOKEN_TTL=86400
LATEXLAB_MINERU_API_BASE=https://mineru.net/api/v4
LATEXLAB_MINERU_TOKEN=
LATEXLAB_PYTHON=python3

# =============================================================================
# ADVANCED
# =============================================================================
# CLAUDE_TOOL_APPROVAL_TIMEOUT_MS=55000
